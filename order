task.spawn(function()
    local brandNames = {"Script by Trgianghe", "Ngô Huy Trường Giang"}
    local currentIdx = 1
    while true do
        task.wait(4)
        _S:Create(brandLabel, TweenInfo.new(0.6), {TextTransparency = 1}):Play()
        task.wait(0.6)
        currentIdx = currentIdx == 1 and 2 or 1
        brandLabel.Text = brandNames[currentIdx]
        _S:Create(brandLabel, TweenInfo.new(0.6), {TextTransparency = 0}):Play()
    end
end)

local lastUpdate, frameCount, currentFPS = os.clock(), 0, 60
_R.RenderStepped:Connect(function()
    statsLabel.TextColor3 = Color3.fromHSV((tick() * 0.4) % 1, 0.7, 1)
    frameCount = frameCount + 1
    if os.clock() - lastUpdate >= 0.5 then
        currentFPS = math.floor(frameCount / (os.clock() - lastUpdate))
        frameCount, lastUpdate = 0, os.clock()
    end
    local sT = _W.DistributedGameTime 
    statsLabel.Text = string.format("🕒 Time: %s\n🚀 Fps:  %d\n📶 Ping: %d ms\n👥 Players: %d", 
        string.format("%02d:%02d:%02d", sT/3600, (sT/60)%60, sT%60), 
        currentFPS, math.floor(L_P:GetNetworkPing()*1000), #_P:GetPlayers())
end)

-- Logic Hop SV (Countdown)
local hopping = false
hopBtn.MouseButton1Click:Connect(function()
    if hopping then return end
    hopping = true
    hopBtn.Text = "Searching..."
    task.spawn(function()
        local success, r = pcall(function() return _H:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100")) end)
        if success and r and r.data then
            for _,v in pairs(r.data) do
                if v.playing < v.maxPlayers and v.id ~= game.JobId then
                    _T:TeleportToPlaceInstance(game.PlaceId, v.id, L_P)
                    break
                end
            end
        end
        for i = 3, 1, -1 do hopBtn.Text = "Fail! Retry in "..i.."s" task.wait(1) end
        hopBtn.Text = "🚀 Hop Server"
        hopping = false
    end)
end)


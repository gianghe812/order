local isHopping = false
hopBtn.MouseButton1Click:Connect(function()
    if isHopping then return end
    isHopping = true
    hopBtn.Text = "Searching..."
    local success, result = pcall(function() return _H:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100")) end)
    local found = false
    if success and result.data then
        for _, v in pairs(result.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                found = true
                _T:TeleportToPlaceInstance(game.PlaceId, v.id, L_P)
                break
            end
        end
    end
    if not found then
        for i = 3, 1, -1 do hopBtn.Text = "Fail! Retry in "..i.."s" task.wait(1) end
        hopBtn.Text = "🚀 Hop Server"
        isHopping = false
    end
end)

